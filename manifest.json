{
  "manifest_version": 3,
  "name": "로아 떠상",
  "version": "1.0.5",
  "description": "로스트아크의 떠돌이 상인에서 전설 카드가 떴을 때의 알림이나 현재 나와있는 전설 카드를 알려줍니다. 서버선택 기능 추가.",
  "action": {
    "default_title": "로아 떠상",
    "default_popup": "index.html"
  },
  "permissions": ["alarms", "notifications", "storage"],
  "background": { "service_worker": "background.js" },
  "host_permissions": ["https://api.korlark.com/*"],
  "icons": {
    "128": "icons/icon_128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["MerchantList.json"],
      "matches": ["<all_urls>"]
    }
  ]
}

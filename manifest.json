{
  "manifest_version": 3,
  "name": "로스트아크 떠상 알리미",
  "version": "1.0.3",
  "description": "로스트아크(로아) 떠돌이 상인(떠상)의 전설 카드 판매 정보를 자동으로 확인하고 알려주는 확장 프로그램입니다.",
  "action": {
    "default_title": "로스트아크 떠상 알리미",
    "default_popup": "index.html"
  },
  "permissions": ["alarms", "notifications", "storage"],
  "background": { "service_worker": "background.js" },
  "host_permissions": ["https://api.korlark.com/*"],
  "icons": {
    "128": "icons/icon_128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["MerchantList.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
